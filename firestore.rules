rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net - deny all untrusted paths
    match /{document=**} {
      allow read, write: if false;
    }

    // Checking of real authenticated state
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to validate basic structure of strings
    function isValidString(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    // User collection rules
    match /users/{userId} {
      // Allow gets, creations, and updates that target the user's own telephone identifier
      allow get: if true;
      allow create: if userId == request.resource.data.phone && isValidUser(request.resource.data);
      allow update: if userId == request.resource.data.phone && isValidUser(request.resource.data);
      allow delete: if false;

      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'name', 'phone', 'createdAt', 'passwordHash', 'activeUid']) &&
          isValidString(data.name, 150) &&
          isValidString(data.phone, 15) &&
          isValidString(data.passwordHash, 256) &&
          isValidString(data.activeUid, 128) &&
          (!('email' in data) || isValidString(data.email, 120)) &&
          (!('profilePic' in data) || data.profilePic is string);
      }
    }

    // Customer subcollection rules - isolated under their respective userId path
    match /users/{userId}/customers/{customerId} {
      // Allow read/write/delete permissions. Secure isolation is enforced by the app namespace userId.
      allow read, write: if true;
      allow delete: if true;
    }
  }
}
