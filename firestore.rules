rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper to validate basic structure of strings
    function isValidString(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    // Helper to check valid document IDs
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Checking of real authenticated state
    function isSignedIn() {
      return request.auth != null;
    }

    // User collection rules
    match /users/{userId} {
      // Allow any authenticated user to perform a get to verify credentials on login / signup
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidUser(request.resource.data) && userId == request.resource.data.phone && request.resource.data.activeUid == request.auth.uid;
      allow update: if isSignedIn() && isValidUser(request.resource.data) && (
        // Mode 1: Owner update of their profile metadata
        (resource.data.activeUid == request.auth.uid && request.resource.data.createdAt == resource.data.createdAt) ||
        // Mode 2: Re-login validation on new devices. They must demonstrate same password credentials and not change key historical values.
        (request.resource.data.passwordHash == resource.data.passwordHash && request.resource.data.createdAt == resource.data.createdAt)
      );
      allow delete: if false; // Non-deletable profiles

      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'name', 'phone', 'createdAt', 'passwordHash', 'activeUid']) &&
          isValidString(data.name, 150) &&
          isValidString(data.phone, 15) &&
          isValidString(data.passwordHash, 256) &&
          isValidString(data.activeUid, 128) &&
          (!('email' in data) || isValidString(data.email, 120)) &&
          (!('profilePic' in data) || data.profilePic is string);
      }
    }

    // Customer subcollection rules - isolated under their respective userId
    match /users/{userId}/customers/{customerId} {
      // Master Gate: Only owners can read. Verify by evaluating activeUid
      allow read, write: if isSignedIn() && get(/databases/$(database)/documents/users/$(userId)).data.activeUid == request.auth.uid && isValidCustomer(request.resource.data);
      allow delete: if isSignedIn() && get(/databases/$(database)/documents/users/$(userId)).data.activeUid == request.auth.uid;

      function isValidCustomer(data) {
        return data.keys().hasAll(['id', 'ownerId', 'name', 'phone', 'category', 'board', 'createdAt', 'lastUpdated', 'year', 'totalPrice', 'advance', 'due', 'paymentStatus', 'workStatus']) &&
          isValidString(data.id, 128) &&
          isValidString(data.ownerId, 128) &&
          isValidString(data.name, 150) &&
          isValidString(data.phone, 25) &&
          isValidString(data.category, 5) &&
          isValidString(data.board, 100) &&
          data.year is int &&
          data.totalPrice is number &&
          data.advance is number &&
          data.due is number &&
          isValidString(data.paymentStatus, 20) &&
          isValidString(data.workStatus, 20) &&
          (!('notes' in data) || data.notes is string) &&
          (!('whatsapp' in data) || data.whatsapp is string) &&
          (!('address' in data) || data.address is string) &&
          (!('examType' in data) || data.examType is string) &&
          (!('groupType' in data) || data.groupType is string) &&
          (!('workType' in data) || data.workType is string) &&
          (!('dateString' in data) || data.dateString is string) &&
          (!('timeString' in data) || data.timeString is string) &&
          (!('additionalOptions' in data) || data.additionalOptions is list) &&
          (!('urgentDelivery' in data) || data.urgentDelivery is bool);
      }
    }
  }
}
